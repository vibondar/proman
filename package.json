{
  "name": "proman",
  "displayName": "Proman",
  "description": "Task tree in .proman/: statuses, Agent/MCP, team Git sync, GitHub Issues — for Cursor/VS Code developers.",
  "version": "0.3.15",
  "publisher": "proman",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:proman.tree"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "proman",
          "title": "Proman",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "proman": [
        {
          "id": "proman.tree",
          "name": "%proman.views.tree.name%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "proman.tree",
        "contents": "%proman.viewsWelcome%"
      }
    ],
    "commands": [
      {
        "command": "proman.open",
        "title": "%proman.command.open.title%",
        "icon": "$(list-tree)"
      },
      {
        "command": "proman.importPlanningDocs",
        "title": "%proman.command.importPlanningDocs.title%",
        "icon": "$(file-code)"
      },
      {
        "command": "proman.setPlanningDirectory",
        "title": "%proman.command.setPlanningDirectory.title%"
      },
      {
        "command": "proman.runTaskInAgent",
        "title": "%proman.command.runTaskInAgent.title%",
        "icon": "$(rocket)"
      },
      {
        "command": "proman.driveTree",
        "title": "%proman.command.driveTree.title%",
        "icon": "$(debug-start)"
      },
      {
        "command": "proman.stopDrive",
        "title": "%proman.command.stopDrive.title%",
        "icon": "$(debug-stop)"
      },
      {
        "command": "proman.recalculateDependencies",
        "title": "%proman.command.recalculateDependencies.title%"
      },
      {
        "command": "proman.reloadTree",
        "title": "%proman.command.reloadTree.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "proman.searchTree",
        "title": "%proman.command.searchTree.title%",
        "icon": "$(search)"
      },
      {
        "command": "proman.clearTreeSearch",
        "title": "%proman.command.clearTreeSearch.title%",
        "icon": "$(clear-all)"
      },
      {
        "command": "proman.toggleMyTasks",
        "title": "%proman.command.toggleMyTasks.title%",
        "icon": "$(account)"
      },
      {
        "command": "proman.setCurrentUser",
        "title": "%proman.command.setCurrentUser.title%",
        "icon": "$(person)"
      },
      {
        "command": "proman.assignTask",
        "title": "%proman.command.assignTask.title%",
        "icon": "$(mention)"
      },
      {
        "command": "proman.gitPull",
        "title": "%proman.command.gitPull.title%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "proman.gitPush",
        "title": "%proman.command.gitPush.title%",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "proman.resolveMerge",
        "title": "%proman.command.resolveMerge.title%"
      },
      {
        "command": "proman.enableGitSync",
        "title": "%proman.command.enableGitSync.title%"
      },
      {
        "command": "proman.configureGitSync",
        "title": "%proman.command.configureGitSync.title%"
      },
      {
        "command": "proman.enableGithubIssues",
        "title": "%proman.command.enableGithubIssues.title%",
        "icon": "$(github)"
      },
      {
        "command": "proman.configureGithubIssues",
        "title": "%proman.command.configureGithubIssues.title%"
      },
      {
        "command": "proman.syncGithubIssues",
        "title": "%proman.command.syncGithubIssues.title%",
        "icon": "$(sync)"
      },
      {
        "command": "proman.copyAgentPrompt",
        "title": "%proman.command.copyAgentPrompt.title%"
      },
      {
        "command": "proman.enrichTreeFromMd",
        "title": "%proman.command.enrichTreeFromMd.title%"
      },
      {
        "command": "proman.addRootTask",
        "title": "%proman.command.addRootTask.title%",
        "icon": "$(add)"
      },
      {
        "command": "proman.addChildTask",
        "title": "%proman.command.addChildTask.title%",
        "icon": "$(add)"
      },
      {
        "command": "proman.deleteTask",
        "title": "%proman.command.deleteTask.title%",
        "icon": "$(trash)"
      },
      {
        "command": "proman.deleteTree",
        "title": "%proman.command.deleteTree.title%",
        "icon": "$(trash)"
      },
      {
        "command": "proman.exportTreeMd",
        "title": "%proman.command.exportTreeMd.title%",
        "icon": "$(export)"
      },
      {
        "command": "proman.openTaskDetails",
        "title": "%proman.command.openTaskDetails.title%",
        "icon": "$(edit)"
      },
      {
        "command": "proman.setStatusTodo",
        "title": "%proman.command.setStatusTodo.title%"
      },
      {
        "command": "proman.setStatusNew",
        "title": "%proman.command.setStatusNew.title%"
      },
      {
        "command": "proman.setStatusInProgress",
        "title": "%proman.command.setStatusInProgress.title%"
      },
      {
        "command": "proman.setStatusDone",
        "title": "%proman.command.setStatusDone.title%"
      },
      {
        "command": "proman.setStatusNeedsRework",
        "title": "%proman.command.setStatusNeedsRework.title%"
      },
      {
        "command": "proman.setStatusError",
        "title": "%proman.command.setStatusError.title%"
      },
      {
        "command": "proman.selectTask",
        "title": "%proman.command.selectTask.title%"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "proman.searchTree",
          "when": "view == proman.tree",
          "group": "navigation@0"
        },
        {
          "command": "proman.toggleMyTasks",
          "when": "view == proman.tree",
          "group": "navigation@1"
        },
        {
          "command": "proman.clearTreeSearch",
          "when": "view == proman.tree && (proman.treeFiltered || proman.pathHighlighted || proman.myTasksOnly)",
          "group": "navigation@2"
        },
        {
          "command": "proman.gitPull",
          "when": "view == proman.tree",
          "group": "navigation@3"
        },
        {
          "command": "proman.gitPush",
          "when": "view == proman.tree",
          "group": "navigation@4"
        },
        {
          "command": "proman.driveTree",
          "when": "view == proman.tree",
          "group": "navigation@5"
        },
        {
          "command": "proman.addRootTask",
          "when": "view == proman.tree",
          "group": "navigation@6"
        },
        {
          "command": "proman.importPlanningDocs",
          "when": "view == proman.tree",
          "group": "navigation@7"
        },
        {
          "command": "proman.reloadTree",
          "when": "view == proman.tree",
          "group": "navigation@8"
        }
      ],
      "view/item/context": [
        {
          "command": "proman.driveTree",
          "when": "view == proman.tree && viewItem == promanTreeSection",
          "group": "inline@1"
        },
        {
          "command": "proman.addRootTask",
          "when": "view == proman.tree && viewItem == promanTreeSection",
          "group": "inline@2"
        },
        {
          "command": "proman.exportTreeMd",
          "when": "view == proman.tree && viewItem == promanTreeSection",
          "group": "inline@3"
        },
        {
          "command": "proman.deleteTree",
          "when": "view == proman.tree && viewItem == promanTreeSection",
          "group": "inline@4"
        },
        {
          "command": "proman.driveTree",
          "when": "view == proman.tree && viewItem == promanTreeSection",
          "group": "1_edit"
        },
        {
          "command": "proman.exportTreeMd",
          "when": "view == proman.tree && viewItem == promanTreeSection",
          "group": "1_edit"
        },
        {
          "command": "proman.deleteTree",
          "when": "view == proman.tree && viewItem == promanTreeSection",
          "group": "9_danger"
        },
        {
          "command": "proman.openTaskDetails",
          "when": "view == proman.tree && viewItem == promanTask",
          "group": "inline@1"
        },
        {
          "command": "proman.addChildTask",
          "when": "view == proman.tree && viewItem == promanTask",
          "group": "inline@2"
        },
        {
          "command": "proman.deleteTask",
          "when": "view == proman.tree && viewItem == promanTask",
          "group": "inline@3"
        },
        {
          "command": "proman.runTaskInAgent",
          "when": "view == proman.tree && viewItem == promanTask",
          "group": "inline@4"
        },
        {
          "command": "proman.addChildTask",
          "when": "view == proman.tree && viewItem == promanTask",
          "group": "1_edit"
        },
        {
          "command": "proman.openTaskDetails",
          "when": "view == proman.tree && viewItem == promanTask",
          "group": "1_edit"
        },
        {
          "command": "proman.assignTask",
          "when": "view == proman.tree && viewItem == promanTask",
          "group": "1_edit"
        },
        {
          "command": "proman.setCurrentUser",
          "when": "view == proman.tree",
          "group": "1_edit"
        },
        {
          "command": "proman.setStatusInProgress",
          "when": "view == proman.tree && viewItem == promanTask",
          "group": "2_status@1"
        },
        {
          "command": "proman.setStatusDone",
          "when": "view == proman.tree && viewItem == promanTask",
          "group": "2_status@2"
        },
        {
          "command": "proman.setStatusNeedsRework",
          "when": "view == proman.tree && viewItem == promanTask",
          "group": "2_status@3"
        },
        {
          "command": "proman.setStatusError",
          "when": "view == proman.tree && viewItem == promanTask",
          "group": "2_status@4"
        },
        {
          "command": "proman.setStatusNew",
          "when": "view == proman.tree && viewItem == promanTask",
          "group": "2_status@5"
        },
        {
          "command": "proman.setStatusTodo",
          "when": "view == proman.tree && viewItem == promanTask",
          "group": "2_status@6"
        },
        {
          "command": "proman.copyAgentPrompt",
          "when": "view == proman.tree && viewItem == promanTask",
          "group": "3_agent"
        },
        {
          "command": "proman.deleteTask",
          "when": "view == proman.tree && viewItem == promanTask",
          "group": "9_danger"
        }
      ]
    },
    "configuration": {
      "title": "Proman",
      "properties": {
        "proman.autoDiscoverOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "%proman.config.autoDiscover%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "package": "vsce package --no-dependencies --baseContentUrl https://example.com/proman --baseImagesUrl https://example.com/proman",
    "install:cursor": "npm run package && cursor --install-extension \"$(ls -t *.vsix | head -1)\" --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
